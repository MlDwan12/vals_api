# Version control
.git
.gitignore
.gitattributes

# Dependencies (installed fresh in Docker)
node_modules

# Pre-built output (built fresh inside Docker)
dist

# Test files
test
coverage
.nyc_output

# Environment files (pass via docker-compose env_file or runtime secrets)
.env
.env.*

# Large files
*.tar
*.tar.gz
*.zip

# Uploaded user files (should be a mounted volume in production)
uploads

# Docker config (not needed inside the image)
Dockerfile
docker-compose.yml
docker-compose*.yml
docker

# Documentation and dev-tool configs
README.md
*.md
insomnia.json
.prettierrc
eslint.config.mjs

# OS / IDE artifacts
.DS_Store
*.swp
*.swo
.vscode
.idea

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock
