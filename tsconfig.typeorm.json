{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "resolvePackageJsonExports": false,
    "target": "ES2021",
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "types": ["node"],
    "outDir": "./dist",
    "incremental": false,
    "paths": {
      "src/*": ["./*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
